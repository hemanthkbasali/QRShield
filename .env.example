QRSHIELD_SECRET_KEY=change-me-to-a-long-random-value
QRSHIELD_DEBUG=True
QRSHIELD_ALLOWED_HOSTS=127.0.0.1,localhost

# Use mysql for the required project database.
QRSHIELD_DB_ENGINE=sqlite
